# Backend Environment Variables
# Copy this file to .env in the parent directory and fill in your values

# ============================================
# CORE CONFIGURATION
# ============================================

# Server Port
PORT=3001

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS and OAuth redirects)
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Backend URL (for OAuth callbacks)
BACKEND_URL=http://localhost:3001

# ============================================
# AI CONFIGURATION (Required)
# ============================================

# OpenAI API Key (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================

# Resend API Key (for email verification and password reset)
# Get your key from: https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# ============================================
# GOOGLE OAUTH (Optional)
# ============================================

# Google OAuth Credentials
# Get from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized redirect URI: http://localhost:3001/api/auth/google/callback
# 3. For production, add: https://yourdomain.com/api/auth/google/callback

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# APPLE SIGN-IN (Optional)
# ============================================

# Apple Sign-In Credentials
# Get from: https://developer.apple.com
# 1. Create a Service ID in Identifiers
# 2. Enable Sign in with Apple
# 3. Add return URL: http://localhost:3001/api/auth/apple/callback
# 4. Create a Key for Sign in with Apple
# 5. Download the .p8 private key file

# Service ID (com.yourcompany.yourapp)
APPLE_CLIENT_ID=com.yourcompany.yourapp

# Team ID (found in Apple Developer membership)
APPLE_TEAM_ID=YOUR10DIGIT

# Key ID (from the key you created)
APPLE_KEY_ID=YOUR10CHAR

# Private Key (contents of the .p8 file, with newlines as \n)
# Example: -----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----

# ============================================
# DATABASE (Optional)
# ============================================

# SQLite database path (defaults to ./server/evos.db)
# DATABASE_PATH=/path/to/evos.db
